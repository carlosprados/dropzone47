# dropzone47 (Go) configuration — every setting is a DROPZONE47_* environment variable.
# Used by docker-compose (env_file) and honored directly by the binary. CLI flags of the
# same name override these. Values shown are the defaults.

# Telegram bot token (required for `serve`)
DROPZONE47_TELEGRAM_TOKEN=

# Downloader backend: lux | yt-dlp | auto (default yt-dlp; lux/auto are opt-in)
DROPZONE47_DOWNLOADER=yt-dlp

# Working paths
DROPZONE47_DOWNLOAD_DIR=./downloads
DROPZONE47_SESSIONS_DB=./downloads/sessions

# Limits and quality
DROPZONE47_TELEGRAM_MAX_MB=1900
DROPZONE47_MAX_HEIGHT=720
# Descending resolutions to try when a video exceeds the size limit (capped at max-height)
DROPZONE47_VIDEO_HEIGHT_LADDER=720,480,360,240
DROPZONE47_AUDIO_KBITRATE=128
DROPZONE47_SOCKET_TIMEOUT=30
DROPZONE47_YTDLP_RETRIES=3
DROPZONE47_CLEANUP_AFTER_SEND=false

# Concurrency and abuse controls
DROPZONE47_MAX_CONCURRENT=2
# Per-user quota: max downloads per window; 0 disables. Window accepts 1h, 30m, 3600s…
DROPZONE47_RATE_LIMIT_MAX=5
DROPZONE47_RATE_LIMIT_WINDOW=1h

# User-facing language: en or es
DROPZONE47_LANG=en

# Log level: debug | info | warn | error
DROPZONE47_LOG_LEVEL=info
