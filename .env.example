# Telegram bot token (required)
TELEGRAM_BOT_TOKEN=

# Working directories
DOWNLOAD_DIR=./downloads
SESSIONS_DB=./downloads/sessions

# Limits and settings
TELEGRAM_MAX_MB=1900
MAX_HEIGHT=720
# Resolutions (descending) to try when a video exceeds TELEGRAM_MAX_MB. Capped at MAX_HEIGHT.
VIDEO_HEIGHT_LADDER=720,480,360,240
AUDIO_KBITRATE=128
SOCKET_TIMEOUT=30
YTDLP_RETRIES=3
CLEANUP_AFTER_SEND=false

# Concurrency and abuse controls
MAX_CONCURRENT_DOWNLOADS=2
# Per-user quota: RATE_LIMIT_MAX downloads per RATE_LIMIT_WINDOW seconds (0 disables it)
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=3600

# User-facing language for bot messages: en or es
BOT_LANG=en

# Log level (optional): DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
